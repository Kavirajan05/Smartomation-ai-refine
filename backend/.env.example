# Copy this file to backend/.env and fill your values.
# Each demo has isolated command + credentials.
# Commands receive request JSON on stdin.

DEMO1_COMMAND=python ../demo-folder-1/main.py
DEMO1_TIMEOUT_SECONDS=180
DEMO1_SMTP_HOST=smtp.gmail.com
DEMO1_SMTP_PORT=587
DEMO1_SMTP_USERNAME=demo1@example.com
DEMO1_SMTP_PASSWORD=app-password-1
DEMO1_SMTP_FROM=demo1@example.com
DEMO1_SMTP_USE_TLS=true
DEMO1_EMAIL_SUBJECT=Demo 1 result
# Example custom credential for demo1 runner:
# DEMO1_OPENAI_API_KEY=...

DEMO2_COMMAND=python ../demo-folder-2/main.py
